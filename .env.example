# Security
SECRET_KEY=your_super_secret_jwt_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Admin Defaults
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@123

# Database (PostgreSQL - Async)
# Local Example: postgresql+asyncpg://postgres:password@localhost:5432/pharmacy
# Supabase Example: postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.[YOUR-REF].supabase.co:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/pharmacy

# Telegram Bot
BOT_TOKEN=your_bot_token_here
WEBHOOK_URL=https://your-domain.onrender.com/webhook/telegram
ADMINS=123456789,987654321

# App Settings
DEBUG=True
ENVIRONMENT=development
